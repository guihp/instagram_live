# Copie para .env (local) ou configure em Lovable → Cloud → Secrets.
# Nunca commite valores reais. Use SEMPRE o seu próprio Supabase e OpenRouter.

# Supabase — Settings → API (Project URL + anon key)
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# Server-only — nunca exponha no frontend
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
OPENROUTER_API_KEY=sua_chave_openrouter_aqui

# Migrations automáticas no /setup (escolha uma opção):
# DATABASE_URL=postgresql://postgres.[ref]:[senha]@aws-0-[regiao].pooler.supabase.com:5432/postgres
# SUPABASE_DB_PASSWORD=senha_do_banco

# Opcional: URL pública do app (referer para OpenRouter)
# VITE_APP_URL=https://seu-dominio.com

# Opcional: após aumentar "Global file size limit" no Supabase Storage (requer Pro)
# SUPABASE_STORAGE_MAX_BYTES=524288000
